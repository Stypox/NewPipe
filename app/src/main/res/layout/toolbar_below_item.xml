<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/toolbarBelowItem"
    android:layout_height="@dimen/toolbarBelowItemHeight"
    android:layout_width="fill_parent"
    android:gravity="center"
    android:orientation="horizontal"
    android:layout_marginTop="-12dp"
    android:layout_marginBottom="@dimen/toolbarBelowItemMinusHeight"
    android:visibility="gone">

    <ImageButton
        android:layout_width="@dimen/toolbarBelowItemHeight"
        android:layout_height="@dimen/toolbarBelowItemHeight"
        android:src="?attr/share"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:clickable="true"
        android:focusable="true" />

    <ImageButton
        android:layout_width="@dimen/toolbarBelowItemHeight"
        android:layout_height="@dimen/toolbarBelowItemHeight"
        android:src="?attr/ic_playlist_add"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:clickable="true"
        android:focusable="true" />

    <ImageButton
        android:layout_width="@dimen/toolbarBelowItemHeight"
        android:layout_height="@dimen/toolbarBelowItemHeight"
        android:src="?attr/ic_delete"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:clickable="true"
        android:focusable="true" />

    <ImageButton
        android:layout_width="@dimen/toolbarBelowItemHeight"
        android:layout_height="@dimen/toolbarBelowItemHeight"
        android:src="?attr/ic_set_playlist_thumbnail"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:clickable="true"
        android:focusable="true" />

    <Space
        android:id="@+id/guideline"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="horizontal" />

    <ImageButton
        android:layout_width="@dimen/toolbarBelowItemHeight"
        android:layout_height="@dimen/toolbarBelowItemHeight"
        android:src="?attr/download"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:clickable="true"
        android:focusable="true" />

    <ImageButton
        android:layout_width="@dimen/toolbarBelowItemHeight"
        android:layout_height="@dimen/toolbarBelowItemHeight"
        android:src="?attr/audio"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:clickable="true"
        android:focusable="true" />

    <ImageButton
        android:layout_width="@dimen/toolbarBelowItemHeight"
        android:layout_height="@dimen/toolbarBelowItemHeight"
        android:src="?attr/popup"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:clickable="true"
        android:focusable="true" />

    <ImageButton
        android:layout_width="@dimen/toolbarBelowItemHeight"
        android:layout_height="@dimen/toolbarBelowItemHeight"
        android:src="?attr/play"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:clickable="true"
        android:focusable="true" />

</LinearLayout>